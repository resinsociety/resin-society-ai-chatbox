# Resin Society AI Chat environment
# Keep this separate from GREET. Do not paste GREET Chatwoot inbox tokens or GREET database URLs here.

RESIN_SAFE_TEST_MODE=true
RESIN_ENABLE_CHATWOOT_SEND=false
RESIN_TARGET_RESPONSE_SECONDS=5
RESIN_CHAT_WORKERS=4
RESIN_AUTO_CLOSE_ENABLED=true
RESIN_AUTO_CLOSE_DELAY_SECONDS=900
RESIN_SUPPORT_EMAIL=hello@resinsociety.net

# Shopify Admin API for Resin Society only
RESIN_SHOPIFY_STORE_DOMAIN=resinsociety.net
RESIN_SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01

# OpenAI
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-4.1-mini

# Chatwoot: use a NEW Resin Society website inbox/channel, not GREET Dog Website Chat
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
RESIN_CHATWOOT_INBOX_ID=
RESIN_CHATWOOT_WEBSITE_TOKEN=
RESIN_CHATWOOT_WEBHOOK_SECRET=
RESIN_HUMAN_SUPPORT_AGENT_ID=

# Logging: recommended separate Resin database. If sharing infra, keep RESIN_DB_TABLE_PREFIX=resin.
RESIN_DATABASE_URL=
RESIN_DB_TABLE_PREFIX=resin

# Optional legacy fallback names supported inside isolated Resin deployment only
# SHOPIFY_STORE_DOMAIN=
# SHOPIFY_ADMIN_ACCESS_TOKEN=
# DATABASE_URL=
